{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "type": "object",
  "properties": {
    "data": {
      "type": "object",
      "properties": {
        "devices": {
          "type": "object",
          "properties": {
            "vehicle": {
              "type": "array",
              "items": [
                {
                  "type": "object",
                  "properties": {
                    "userId": {
                      "type": "string"
                    },
                    "make": {
                      "type": "string"
                    },
                    "deviceHostId": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string"
                    },
                    "model": {
                      "type": "string"
                    },
                    "year": {
                      "type": "string"
                    },
                    "deviceHostTag": {
                      "type": "string"
                    },
                    "fuelType": {
                      "type": "string"
                    },
                    "dateCreated": {
                      "type": "integer"
                    },
                    "dateUpdated": {
                      "type": "integer"
                    },
                    "configData": {
                      "type": "object",
                      "properties": {
                        "dailyReportEnabled": {
                          "type": "boolean"
                        }
                      },
                      "required": [
                        "dailyReportEnabled"
                      ]
                    },
                    "device": {
                      "type": "array",
                      "items": [
                        {
                          "type": "object",
                          "properties": {
                            "imei": {
                              "type": "string"
                            },
                            "authId": {
                              "type": "string"
                            },
                            "milStatus": {
                              "type": "boolean"
                            },
                            "geofenceBreach": {
                              "type": "boolean"
                            },
                            "ignitionStatus": {
                              "type": "boolean"
                            },
                            "idle": {
                              "type": "boolean"
                            },
                            "deviceType": {
                              "type": "string"
                            },
                            "vehicleType": {
                              "type": "string"
                            },
                            "dongleState": {
                              "type": "string"
                            },
                            "lastAccessDate": {
                              "type": "integer"
                            },
                            "firmwareVersion": {
                              "type": "string"
                            },
                            "pdid": {
                              "type": "string"
                            },
                            "clientmqttuser": {
                              "type": "string"
                            },
                            "clientmqttpass": {
                              "type": "string"
                            }
                          },
                          "required": [
                            "imei",
                            "authId",
                            "milStatus",
                            "geofenceBreach",
                            "ignitionStatus",
                            "idle",
                            "deviceType",
                            "vehicleType",
                            "dongleState",
                            "lastAccessDate",
                            "firmwareVersion",
                            "pdid",
                            "clientmqttuser",
                            "clientmqttpass"
                          ]
                        }
                      ]
                    },
                    "tenantId": {
                      "type": "integer"
                    }
                  },
                  "required": [
                    "userId",
                    "make",
                    "deviceHostId",
                    "name",
                    "model",
                    "year",
                    "deviceHostTag",
                    "fuelType",
                    "dateCreated",
                    "dateUpdated",
                    "configData",
                    "device",
                    "tenantId"
                  ]
                }
              ]
            },
            "tenantDTO": {
              "type": "object",
              "properties": {
                "tenantId": {
                  "type": "integer"
                },
                "image_url": {
                  "type": "string"
                },
                "imageId": {
                  "type": "string"
                },
                "imageThumbnailId": {
                  "type": "string"
                },
                "imageThumbnail_url": {
                  "type": "string"
                }
              },
              "required": [
                "tenantId",
                "image_url",
                "imageId",
                "imageThumbnailId",
                "imageThumbnail_url"
              ]
            }
          },
          "required": [
            "vehicle",
            "tenantDTO"
          ]
        }
      },
      "required": [
        "devices"
      ]
    },
    "responseStatus": {
      "type": "object",
      "properties": {
        "code": {
          "type": "integer"
        },
        "message": {
          "type": "string"
        },
        "serverTime": {
          "type": "integer"
        }
      },
      "required": [
        "code",
        "message",
        "serverTime"
      ]
    }
  },
  "required": [
    "data",
    "responseStatus"
  ]
}